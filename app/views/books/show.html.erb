
    
    <!-- Title -->
    <div class="row">
      <div class="col">
        <div class="header">
          <h1><%= @book.title.titleize %></h1>
        </div>
      </div> 
    </div>

    <!-- Metadata -->
    <div class="row mb-3">
      <div class="col">
          <div class="card">
            <div class="card-body">
            <%= current_user&.admin? ? (link_to @book.user.full_name.titleize, user_path(@book.user)) : @book.user.full_name %> | <%= @book.word_count %> | <%= @book.language %> | <%= @book.genre.genre_type.titleize %>
              <%= link_to edit_book_path(@book), data: { bs_toggle: "tooltip", bs_placement: "top", bs_title: "Edit Book" } do %>
                <i class="bi bi-gear"></i>
              <% end %>
            </div>
          </div>
      </div>
    </div>

    <!-- Description -->
    <div class="row">
      <div class="col">
        <div class="card">
          <div class="card-body">

            <div class="d-grid gap-2">
              <button data-action="click->toggle#switch" data-controller="toggle" data-toggle-target="trigger" class="btn d-flex justify-content-between align-items-center pb-2" type="button" data-bs-toggle="collapse" data-bs-target="#formCollapse" aria-expanded="false" aria-controls="formCollapse">
                <span><i class="bi bi-body-text"></i> Book Description</span> 
                <i data-toggle-target="icon" class="bi bi-arrow-down"></i>
              </button>
            </div>

            <div class="collapse py-3 box" id="formCollapse">
              <%= form_for(@book) do |form| %>

                <div class="input">
                  <%= form.rich_text_area :description, type: "text", class: "form-control", rows: "35" %>
                </div>

                <div class="button d-grid gap-2">
                  <%= form.button "Update Description", type: "submit", class: 'btn btn-outline-primary btn-sm my-2', data: {disable_with: "<i class='fa fa-spinner fa-spin'></i> Saving..."}  %>
                </div>
              <% end %>
            </div>

          </div>
        </div>    
      </div>
    </div>
<!-- Orders -->
<div class="row mt-3">
  <div class="col">
    <div class="card">
      <div class="card-body">

        <% if current_user.editorial_staff? %>
          <h2>Orders</h2>

          <% @book.orders.select(&:persisted?).each do |order| %>
            <h3><%= order.product&.name %></h3>

            <% if order.initial_unedited_manuscript.attached? %>
              <%= link_to 'Download Unedited Manuscript', rails_blob_path(order.initial_unedited_manuscript, disposition: 'attachment'), class: 'btn btn-primary' %>
            <% end %>

            <%= render_state_message(order) %>
          <% end %>
        <% else %>
          user
        <% end %>

      </div>
    </div>
  </div>
</div>






