<div class="header">
  <h1>Books</h1>
</div>

  <table class="table table-bordered table-hover">
    <thead>
      <tr>
    

            <th>Title</th>
            <th>User</th>
            <th>Language</th>
            <th>Genre</th>
            <th>Word count</th>

          <th></th>
        
      </tr>
    </thead>

    <tbody>
      <% @books.each do |book| %>
        <%= content_tag :tr, id: dom_id(book), class: dom_class(book) do %>
          
                      <td><%= book.title.titleize %></td>
                      <td><%= book.user.full_name.titleize %></td>
                      <td><%= book.language %></td>
                      <td><%= book.genre.genre_type.titleize %></td>
                      <td><%= book.word_count %></td>
          
            <td>
            
              <%= link_to 'Show', book_path(book), class: "btn btn-outline-success" %>
              <%= link_to 'Edit', edit_book_path(book), class: "btn btn-outline-primary" %>
              <%= button_to 'Delete', book_path(book), method: :delete, form: { data: { turbo_confirm: "Are you sure you want to kill this bad boy?" }}, class: 'btn btn-outline-danger' %> 
 
            
            </td>
          
        <% end %>
      <% end %>
    </tbody>
  </table>
