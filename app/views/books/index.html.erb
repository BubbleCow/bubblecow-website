<div class="header">
  <h1>Books</h1>
</div>

  <table class="table table-bordered table-hover">
    <thead>
      <tr>
    

            <th>Title</th>
            <th>User</th>
            <th>Language</th>
            <th>Genre</th>
            <th>Word count</th>

          <th></th>
        
      </tr>
    </thead>

    <tbody>
      <% @books.each do |book| %>
        <%= content_tag :tr, id: dom_id(book), class: dom_class(book) do %>
          
                      <td><%= book.title.titleize %></td>
                      <td><%= book.user.full_name.titleize %></td>
                      <td><%= book.language %></td>
                      <td><%= book.genre.genre_type.titleize %></td>
                      <td><%= book.word_count %></td>
          
            <td><%= link_to 'Show', book_path(book) %></td>
          
        <% end %>
      <% end %>
    </tbody>
  </table>
